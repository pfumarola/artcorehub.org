# Copiare in .env e impostare i valori per il build
# MAINTENANCE_MODE: attiva la pagina Coming Soon (true/false)
MAINTENANCE_MODE=false
# NUXT_PUBLIC_SITE_URL: URL del sito per sitemap e SEO
NUXT_PUBLIC_SITE_URL=https://artcorehub.org
# NUXT_PUBLIC_PAYPAL_DONATE_URL: https://paypal.me/artcorehub o PayPal Donate)
NUXT_PUBLIC_PAYPAL_DONATE_URL=https://paypal.me/artcorehub
# NUXT_PUBLIC_INSTAGRAM_URL: profilo Instagram (es. https://instagram.com/artcorehub)
NUXT_PUBLIC_INSTAGRAM_URL=https://instagram.com/artcorehub
# NUXT_PUBLIC_COWORKING_SPOTS_LEFT: posti coworking ancora disponibili (es. 7). Aggiorna e rideploya per cambiare il contatore.
NUXT_PUBLIC_COWORKING_SPOTS_LEFT=10
